# ─────────────────────────────────────────────────────────────
# HopexBackend (NestJS API) — environment example
# Copy to `.env` (git-ignored) to override defaults. All are OPTIONAL:
# the defaults below already work for local + LAN testing.
# ─────────────────────────────────────────────────────────────

# Port the API listens on.
PORT=3000

# Bind address. 0.0.0.0 = reachable from other devices on the same Wi-Fi
# (needed for phone/LAN testing). Use 127.0.0.1 to restrict to this machine.
HOST=0.0.0.0

# MongoDB connection string.
MONGODB_URI=mongodb://localhost:27017/expo2025_db

# CORS allowlist — comma-separated origins. Leave UNSET in dev/LAN to allow any
# origin (credentials stay off, so this is safe and lets phones load the public
# map). Set it explicitly for production, e.g.:
# CORS_ORIGINS=https://dashboard.your-domain.com,https://your-domain.com

# Enable ONLY if you later switch auth to cookies/credentialed requests.
# When true, you MUST also set an explicit CORS_ORIGINS allowlist.
# CORS_CREDENTIALS=false
